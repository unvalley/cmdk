{
  "name": "command-palette-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "check": "biome check && pnpm typecheck && pnpm test && pnpm build && pnpm check:size && pnpm -r --filter='./demo/*' run build",
    "build": "pnpm -r --filter='./packages/*' run build",
    "demo": "pnpm -r --parallel --filter='./demo/*' run dev",
    "test": "pnpm -r --filter='./packages/*' run test",
    "typecheck": "pnpm -r --filter='./packages/*' run typecheck",
    "check:size": "node scripts/check-package-size.mts",
    "check:write": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
