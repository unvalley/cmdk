{
  "name": "@command-palette/react",
  "version": "0.0.1",
  "description": "Unstyled React command palette primitives",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "command-palette",
    "command-menu",
    "react",
    "ui"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unvalley/command-palette.git"
  },
  "homepage": "https://github.com/unvalley/command-palette/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/unvalley/command-palette/issues"
  },
  "scripts": {
    "build": "tsdown && node ./scripts/assert-use-client.mjs",
    "test": "pnpm test:browser && pnpm test:node",
    "test:browser": "vitest run --config vitest.config.ts",
    "test:node": "vitest run --config vitest.node.config.ts",
    "test:watch": "vitest --browser.headless=false",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@command-palette/core": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.4",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "vitest-browser-react": "^2.2.0"
  }
}
